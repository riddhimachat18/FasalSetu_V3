# FasalSetu — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Optional but recommended ──────────────────────────────
# Get from https://openweathermap.org/api (free tier is enough)
OPENWEATHER_API_KEY=

# ── App settings ──────────────────────────────────────────
LOG_LEVEL=INFO

# Set to "true" to output JSON logs (useful for production/ELK)
JSON_LOGS=false

# Agmarknet / data.gov.in API key for real market prices (optional)
# Without this, market_agent falls back to hardcoded MSP data
AGMARKNET_API_KEY=
